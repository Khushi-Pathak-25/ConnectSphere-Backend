# ── Maven build output ──────────────────────────────────────────────────────
target/
*.jar
*.war
*.ear
*.class

# ── IDE files ────────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
.eclipse/
.settings/
.classpath
.project
.factorypath

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
build.log

# ── Uploaded media files ─────────────────────────────────────────────────────
media-service/uploads/

# ── Sensitive configuration — never commit real credentials ──────────────────
# application.yml is committed with env var placeholders (no real credentials)
*/src/main/resources/application.properties

# ── Local environment variables ───────────────────────────────────────────────
.env
.env.local

# ── Node (root package-lock from sonar) ──────────────────────────────────────
node_modules/
package-lock.json

# ── Frontend (separate repository) ───────────────────────────────────────────
frontend/

# ── SonarQube ─────────────────────────────────────────────────────────────────
sonar-project.properties
sonar-scan.bat
.sonar/

# ── Docker volumes ────────────────────────────────────────────────────────────
mysql_data/
